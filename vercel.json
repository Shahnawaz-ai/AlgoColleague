{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/css/(.*)",
      "destination": "/public/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/public/js/$1"
    },
    {
      "source": "/",
      "destination": "/public/landing.html"
    },
    {
      "source": "/connect",
      "destination": "/public/connect.html"
    },
    {
      "source": "/setup",
      "destination": "/public/setup.html"
    },
    {
      "source": "/app",
      "destination": "/public/app.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/public/app.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
